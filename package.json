{
  "name": "inner-compass",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered journaling coach combining biblical psychology and behavioral science",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@stripe/stripe-js": "^5.0.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "ai": "^3.0.0",
    "next": "14.2.35",
    "openai": "^4.50.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^17.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.40",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
